--cleaning invalid dates 

select 
nullif(sls_order_date,0) sls_order_date
from BRONZE.crm_sales_detail
where sls_order_date < = 0
      or len(sls_order_date) != 8 
      or sls_order_date >20500101
      or sls_order_date < 19000101

select 
nullif(sls_ship_date,0) sls_order_date
from BRONZE.crm_sales_detail
where sls_ship_date < = 0
      or len(sls_ship_date) != 8 
      or sls_ship_date >20500101
      or sls_ship_date < 19000101

select 
nullif(sls_due_date,0) sls_order_date
from BRONZE.crm_sales_detail
where sls_due_date < = 0
      or len(sls_due_date) != 8 
      or sls_due_date >20500101
      or sls_due_date < 19000101

      select *
      from BRONZE.crm_sales_detail
      where sls_order_date > sls_ship_date or
            sls_order_date > sls_due_date 
    
    --checking consistency of quntity ,sales,price
    --business rule sales = quantity * price 
     
     select 
        sls_sales,
        sls_quantity,
        sls_price,
        case when sls_sales is null or sls_sales <= 0 or sls_sales !=sls_quantity *abs(sls_price) then sls_quantity * abs(sls_price)
        else sls_sales
        end as sls_sales,
        case when sls_price is null or sls_price <= 0 then sls_sales/nullif(sls_quantity,0)
        else sls_price
        end sls_price
     from BRONZE.crm_sales_detail
     where sls_sales != sls_quantity * sls_price or
           sls_quantity <= 0 or
           sls_price <= 0 or
           sls_sales is null or sls_quantity is null or sls_price is null
   -- order by sls_sales,sls_quantity,sls_price

